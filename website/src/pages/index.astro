---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title id="page-title">{en.title}</title>
		<meta id="page-description" name="description" content={en.description} />
	</head>
	<body class="min-h-screen bg-cream text-slate-800 antialiased">
		<main class="mx-auto flex max-w-xl flex-col items-center px-5 py-10 sm:py-14">
			<header class="flex w-full items-center justify-between">
				<img
					src="/bee-logo.png"
					alt="Bee Korea"
					class="h-10 w-auto sm:h-12"
				/>
				<select
					id="lang-select"
					aria-label="Language"
					class="rounded-md border border-slate-200 bg-white px-2 py-1 text-sm text-slate-700 shadow-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
				>
					{languages.map((l) => (
						<option value={l.code}>{l.label}</option>
					))}
				</select>
			</header>

			<h1 id="i18n-heading" class="mt-10 text-center text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
				{en.heading}
			</h1>

			<p class="mt-5 text-center text-sm sm:text-base text-slate-500">
				<span class="font-mono line-through">ministry-manager-v2.vercel.app</span>
				<span class="mx-2 text-primary">→</span>
				<a
					href={newUrlHref}
					class="font-mono font-semibold text-primary underline decoration-primary/40 underline-offset-4 hover:decoration-primary"
				>
					{newUrl}
				</a>
			</p>

			<a
				href={newUrlHref}
				class="mt-7 inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-5 py-3 text-base font-semibold text-primary-foreground shadow-sm transition hover:bg-primary-hover active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary/40 focus:ring-offset-2"
			>
				<span id="i18n-cta">{en.cta}</span>
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
					<path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638l-3.97-3.97a.75.75 0 011.06-1.06l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06l3.97-3.97H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
				</svg>
			</a>

			<p
				id="i18n-warning"
				class="mt-8 w-full rounded-xl border border-primary-border bg-primary-soft px-4 py-3 text-center text-sm sm:text-base text-slate-700 leading-relaxed"
				set:html={en.warning}
			></p>

			<section class="mt-12 w-full">
				<h2 id="i18n-save-title" class="text-center text-lg font-semibold text-slate-900">
					{en.saveTitle}
				</h2>
				<p id="i18n-save-subtitle" class="mt-1 text-center text-sm text-slate-500">
					{en.saveSubtitle}
				</p>

				<div class="mt-6 grid gap-4 sm:grid-cols-2">
					<div class="rounded-xl border border-slate-200 bg-white p-5">
						<h3 id="i18n-ios-title" class="font-semibold text-slate-900">{en.iosTitle}</h3>
						<ol id="i18n-ios-list" class="mt-3 space-y-2 text-sm text-slate-700">
							{en.ios.map((step, i) => (
								<li class="grid grid-cols-[1.25rem_1fr] gap-2">
									<span class="font-semibold text-primary">{i + 1}.</span>
									<span set:html={step}></span>
								</li>
							))}
						</ol>
					</div>

					<div class="rounded-xl border border-slate-200 bg-white p-5">
						<h3 id="i18n-android-title" class="font-semibold text-slate-900">{en.androidTitle}</h3>
						<ol id="i18n-android-list" class="mt-3 space-y-2 text-sm text-slate-700">
							{en.android.map((step, i) => (
								<li class="grid grid-cols-[1.25rem_1fr] gap-2">
									<span class="font-semibold text-primary">{i + 1}.</span>
									<span set:html={step}></span>
								</li>
							))}
						</ol>
					</div>
				</div>
			</section>

			<footer id="i18n-footer" class="mt-12 text-center text-xs text-slate-400">
				{en.footer}
			</footer>
		</main>

		<script id="i18n-data" type="application/json" set:html={JSON.stringify(translations)}></script>

		<script is:inline>
			(function () {
				const data = JSON.parse(document.getElementById('i18n-data').textContent);
				const supported = Object.keys(data);
				const select = document.getElementById('lang-select');

				function pickLang() {
					const stored = localStorage.getItem('mmv2-lang');
					if (stored && supported.includes(stored)) return stored;
					const candidates = (navigator.languages && navigator.languages.length)
						? navigator.languages
						: [navigator.language || 'en'];
					for (const c of candidates) {
						const base = (c || '').toLowerCase().split('-')[0];
						if (supported.includes(base)) return base;
					}
					return 'en';
				}

				function setText(id, value) {
					const el = document.getElementById(id);
					if (el) el.textContent = value;
				}
				function setHTML(id, value) {
					const el = document.getElementById(id);
					if (el) el.innerHTML = value;
				}
				function setList(id, steps) {
					const el = document.getElementById(id);
					if (!el) return;
					el.innerHTML = steps.map((s, i) =>
						'<li class="grid grid-cols-[1.25rem_1fr] gap-2"><span class="font-semibold text-primary">' +
						(i + 1) + '.</span><span>' + s + '</span></li>'
					).join('');
				}

				function apply(lang) {
					const t = data[lang] || data.en;
					document.documentElement.lang = t.htmlLang;
					document.getElementById('page-title').textContent = t.title;
					document.getElementById('page-description').setAttribute('content', t.description);
					setText('i18n-heading', t.heading);
					setText('i18n-cta', t.cta);
					setHTML('i18n-warning', t.warning);
					setText('i18n-save-title', t.saveTitle);
					setText('i18n-save-subtitle', t.saveSubtitle);
					setText('i18n-ios-title', t.iosTitle);
					setText('i18n-android-title', t.androidTitle);
					setList('i18n-ios-list', t.ios);
					setList('i18n-android-list', t.android);
					setText('i18n-footer', t.footer);
					select.value = lang;
				}

				const initial = pickLang();
				apply(initial);

				select.addEventListener('change', function (e) {
					localStorage.setItem('mmv2-lang', e.target.value);
					apply(e.target.value);
				});
			})();
		</script>
	</body>
</html>
